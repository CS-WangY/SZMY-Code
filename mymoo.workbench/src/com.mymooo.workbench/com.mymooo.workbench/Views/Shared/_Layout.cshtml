<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 蚂蚁工场统一工作平台</title>
    <link rel="stylesheet" href="~/lib/jquery-easyui/themes/bootstrap/easyui.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            padding: 0;
        }
    </style>
</head>
<body>
    <div id="cc" class="easyui-layout" style="width:100%;height:100%;">
        <div data-options="region:'north'" style="height:100px;"></div>
        <div data-options="region:'south',title:'消息',split:true" style="height:100px;"></div>
        <div data-options="region:'west',title:'功能选择',split:true" style="width:200px;">
            @Html.PartialAsync("_Meun", ViewBag.Menus, null).Result
        </div>
        <div data-options="region:'center'" style="padding:5px;background:#eee;">
            @RenderBody()
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-easyui/jquery.easyui.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
