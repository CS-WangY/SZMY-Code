    <!--统一平台提供给ERP调用，mq消息队列mes系统AppId-->
    <add key="WorkbenchForMqMesAppId" value="mymoooerp" />
    <!--统一平台提供给ERP调用，mq消息队列mes系统地址-->
    <add key="WorkbenchForMqMesUrl" value="http://workbench.mymooo.com/RabbitMQ/SendMessage?queueName=topic.spex.order" />
    <!--云仓储地址-->
    <add key="cloudStockUrl" value="http://cloudstockapi.mymooo.com/" />
  </appSettings>

  <system.web>

